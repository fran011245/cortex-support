{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cortex",
  "version": "0.1.0",
  "identifier": "com.fran011245.cortex-support",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cortex — Support Co-Pilot",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["qvac-host.cjs"],
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZBS0VfUFVCS0VZClJXUlRZM1Z5Y0Z3dFpYSmZjMkZ1WjJWMFgyeHBkMjV6YjI0dWMybHpkR1Z1WjJWMFgyeHBkMjV6YjI0PQp",
      "endpoints": [
        "https://github.com/fran011245/cortex-support/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
